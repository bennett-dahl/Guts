# PostgreSQL (Neon, local Docker, etc.) — required for prisma/schema.prisma provider "postgresql"
# Neon pooled URL: add &pgbouncer=true when using the pooler (recommended on Vercel). See setupInstructions.md §8.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Temporary: set to true on Vercel to log more auth detail in Runtime Logs (then remove)
# AUTH_DEBUG="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_TRUST_HOST="true"
# If you use nip.io for LAN + Google OAuth, set base URL (see setupInstructions.md §4.4)
# AUTH_URL="http://192-168-0-104.nip.io:3000"
# Optional: LAN hostname(s) for dev when opening http://YOUR_IP:3000 from phone/tablet (comma-separated, no protocol)
# ALLOWED_DEV_ORIGINS=192.168.0.104
# Spoonacular — https://spoonacular.com/food-api
SPOONACULAR_API_KEY=""
# Instacart Developer Platform — dev: connect.dev.instacart.tools
INSTACART_API_KEY=""
INSTACART_API_BASE="https://connect.dev.instacart.tools"
